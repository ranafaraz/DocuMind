# DocuMind runs fully offline by default. Everything below is OPTIONAL and only
# needed for a real backend. Copy to `.env` to use.

# --- Extractor backend ---
# layout (default, geometry-aware key/value + table association) |
# text   (reading-order ablation: layout-blind) |
# ollama (needs: pip install "documind[ollama]" + a running ollama server) |
# openai (needs: pip install "documind[openai]" + OPENAI_API_KEY)
DOCUMIND_EXTRACTOR_BACKEND=layout

# --- Schema verifier ---
# 1 = reconcile/repair the extracted record against arithmetic constraints
# 0 = take the raw extraction as-is
DOCUMIND_VERIFY=1

# --- Document source ---
# synthetic (default, deterministic generator with ground truth) |
# pdf (needs: pip install "documind[pdf]"; parse a real PDF into tokens+boxes)
DOCUMIND_DOC_BACKEND=synthetic

# --- What to run by default ---
# Doc type: invoice | form | receipt
DOCUMIND_DOCTYPE=invoice

# --- Tunables (deterministic; tweak for experiments) ---
# DOCUMIND_SEED=7
# DOCUMIND_OCR_NOISE=0.15      # P(a total digit is corrupted) -- the verifier's job
# DOCUMIND_ABLATE_LAYOUT=0     # 1 = scramble geometry (the null test)

# --- Optional real backends ---
# DOCUMIND_OLLAMA_MODEL=llama3.1:8b
# DOCUMIND_OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
